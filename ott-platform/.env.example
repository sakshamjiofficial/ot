# ============================================================
# OTT PLATFORM — MASTER ENVIRONMENT FILE
# Copy to .env and fill ALL values before deploying
# NEVER commit .env to git
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=production
DOMAIN=ssooss.store          # ← CHANGE THIS

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=ott_db
POSTGRES_USER=ott_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql://ott_user:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/ott_db

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT (generate: openssl rand -hex 32) ─────────────────────
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_STRING_HERE_0000000000000000000000000000
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_REFRESH_HEX_STRING_000000000000000000
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── Cloudflare ───────────────────────────────────────────────
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_R2_ACCESS_KEY=your_r2_access_key_id
CF_R2_SECRET_KEY=your_r2_secret_access_key
CF_R2_BUCKET=ott-media
CF_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CF_R2_PUBLIC_URL=https://ott-media.r2.dev   # or custom domain
CF_SIGNED_URL_SECRET=CHANGE_ME_HMAC_SECRET_FOR_HLS_SIGNING_000000000000
CF_SIGNED_URL_TTL=3600
CF_ZONE_ID=your_cloudflare_zone_id
CF_API_TOKEN=your_cloudflare_api_token

# ── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Google Play Billing (optional) ───────────────────────────
GOOGLE_PLAY_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project"}

# ── Firebase FCM ─────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-firebase-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@..."}

# ── Meilisearch ──────────────────────────────────────────────
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_KEY=CHANGE_ME_MEILISEARCH_MASTER_KEY_MIN_16_CHARS

# ── SMTP (email invoices, notifications) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@ssooss.store
SMTP_PASS=your_smtp_app_password
SMTP_FROM=OTT Platform <noreply@ssooss.store>

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── Upload ───────────────────────────────────────────────────
UPLOAD_TMP_DIR=/app/uploads
UPLOAD_MAX_SIZE_GB=5

# ── Streaming ────────────────────────────────────────────────
MAX_CONCURRENT_STREAMS=3
HLS_TOKEN_TTL=3600

# ── Worker ───────────────────────────────────────────────────
WORKER_CONCURRENCY=2
MAX_CPU_PERCENT=80
MAX_MEM_PERCENT=85
FFMPEG_THREADS=0
WORK_DIR=/tmp/worker

# ── Subscription ─────────────────────────────────────────────
FREE_TRIAL_DAYS=7
