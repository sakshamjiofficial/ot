# Worker environment — same values as backend .env
NODE_ENV=production
LOG_LEVEL=info
WORK_DIR=/tmp/worker
METRICS_PORT=9091

# Database
DATABASE_URL=postgresql://ott_user:CHANGE_ME@postgres:5432/ott_db

# Redis (BullMQ)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS

# Cloudflare R2
CF_R2_BUCKET=ott-media
CF_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CF_R2_ACCESS_KEY=your_r2_access_key
CF_R2_SECRET_KEY=your_r2_secret_key
CF_R2_PUBLIC_URL=https://ott-media.r2.dev

# Worker tuning
WORKER_CONCURRENCY=2
MAX_CPU_PERCENT=80
MAX_MEM_PERCENT=85
FFMPEG_THREADS=0
