{
  "name": "ott-transcoding-worker",
  "version": "1.0.0",
  "description": "FFmpeg HLS transcoding worker for OTT platform",
  "private": true,
  "scripts": {
    "build":     "tsc -p tsconfig.json",
    "start":     "node dist/worker.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3":            "^3.540.0",
    "@aws-sdk/lib-storage":          "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "bullmq":      "^5.4.2",
    "ioredis":     "^5.3.2",
    "pg":          "^8.11.5",
    "fluent-ffmpeg": "^2.1.3",
    "sharp":       "^0.33.3",
    "prom-client": "^15.1.2",
    "winston":     "^3.13.0",
    "dotenv":      "^16.4.5",
    "uuid":        "^9.0.1",
    "p-limit":     "^4.0.0",
    "fs-extra":    "^11.2.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/fs-extra":      "^11.0.4",
    "@types/node":          "^20.12.7",
    "@types/uuid":          "^9.0.8",
    "ts-node":              "^10.9.2",
    "tsconfig-paths":       "^4.2.0",
    "typescript":           "^5.4.5"
  }
}
