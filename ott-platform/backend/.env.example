# ─── App ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
DOMAIN=ssooss.store

# ─── Database ─────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ott_db
POSTGRES_USER=ott_user
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://ott_user:CHANGE_ME@postgres:5432/ott_db

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS
REDIS_URL=redis://:CHANGE_ME_REDIS@redis:6379

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_HERE_000000000000000000000000
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_REFRESH_SECRET_HERE_00000000000000000
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── Cloudflare R2 ────────────────────────────────────────────
CF_ACCOUNT_ID=your_cf_account_id
CF_R2_ACCESS_KEY=your_r2_access_key_id
CF_R2_SECRET_KEY=your_r2_secret_access_key
CF_R2_BUCKET=ott-media
CF_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CF_SIGNED_URL_SECRET=CHANGE_ME_HMAC_SECRET_FOR_HLS_SIGNING
CF_SIGNED_URL_TTL=3600
CF_ZONE_ID=your_cf_zone_id
CF_API_TOKEN=your_cf_api_token

# ─── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXX
RAZORPAY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Firebase FCM ─────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"...","client_email":"..."}

# ─── Meilisearch ──────────────────────────────────────────────
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_KEY=CHANGE_ME_MEILI_MASTER_KEY

# ─── SMTP ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@ssooss.store
SMTP_PASS=your_smtp_app_password
SMTP_FROM=OTT Platform <noreply@ssooss.store>

# ─── Monitoring ───────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ─── Upload ───────────────────────────────────────────────────
UPLOAD_TMP_DIR=/app/uploads
UPLOAD_MAX_SIZE_GB=5

# ─── Streaming ────────────────────────────────────────────────
MAX_CONCURRENT_STREAMS=3
HLS_TOKEN_TTL=3600

# ─── Worker ───────────────────────────────────────────────────
WORKER_CONCURRENCY=2
MAX_CPU_PERCENT=80
